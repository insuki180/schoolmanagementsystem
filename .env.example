# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/school_db

# For development without PostgreSQL, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./school.db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Super Admin (used by seed script)
SUPER_ADMIN_EMAIL=admin@school.com
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Admin
